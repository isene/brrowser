require 'io/wait'
require 'termpix'
require 'tmpdir'
require 'digest'
require 'fileutils'
require 'yaml'
require 'shellwords'
require 'set'
require 'json'

require_relative '../lib/brrowser/tab'
require_relative '../lib/brrowser/fetcher'
require_relative '../lib/brrowser/renderer'

class Object
  include Rcurses
  include Rcurses::Input
end

# brrowser {{{1
module Brrowser
  VERSION = "0.1.3"
  HOMEPAGE = "https://github.com/isene/brrowser"
  CONFIG_DIR  = File.join(Dir.home, ".brrowser")
  CONFIG_FILE = File.join(CONFIG_DIR, "config.yml")

  DEFAULTS = {
    "show_images"  => true,
    "image_mode"   => "auto",  # auto, termpix, ascii, off
    "homepage"     => "https://github.com/isene/brrowser",
    "search_engine" => "g",
    "download_dir" => "~/Downloads",
    "info_fg"      => 252,
    "info_bg"      => 236,
    "tab_fg"       => 252,
    "tab_bg"       => 234,
    "tab_active"   => 220,
    "content_fg"   => 255,
    "content_bg"   => 0,
    "cmd_fg"       => 252,
    "cmd_bg"       => 234,
    "link_color"   => 81,
    "link_num"     => 39,
    "heading_h1"   => 220,
    "heading_h2"   => 214,
    "heading_h3"   => 208,
    "match_site_colors" => false,
  }

  HELP_HTML = <<~HTML
