    <tr><td>t</td><td>Open URL in new tab</td></tr>
    <tr><td>Tab</td><td>Jump to next link</td></tr>
    <tr><td>Shift-Tab</td><td>Jump to previous link</td></tr>
    <tr><td>Enter</td><td>Follow current/numbered link</td></tr>
